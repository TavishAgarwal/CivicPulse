# ============================================================
# CivicPulse — .gitignore
# ============================================================

# ─── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── ML Models & Data ─────────────────────────────────────────
# Never commit trained models or real data to git
src/ml/models/trained/
data/raw/
data/real/
*.pkl
*.joblib
*.h5
*.pt
*.onnx

# Synthetic data is OK to commit — real data is not
!data/synthetic/

# ─── Node / React ─────────────────────────────────────────────
node_modules/
src/dashboard/build/
src/dashboard/.env
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ─── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ─── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ─── Test Artifacts ───────────────────────────────────────────
.pytest_cache/
coverage.xml
test-results/

# ─── Terraform (if used for infra) ────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
