# ============================================================
# CivicPulse — .gitignore
# Security-hardened for GitHub push
# ============================================================

# ─── 🔐 SECRETS & API KEYS (CRITICAL) ────────────────────────
# NEVER commit these files — they contain real credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
secrets/
service_account.json
**/service_account.json
google-services.json
**/google-services.json
GoogleService-Info.plist
**/GoogleService-Info.plist

# ─── Firebase ─────────────────────────────────────────────────
.firebase/
.firebaserc
firebase-debug.log
firebase-debug.*.log
ui-debug.log

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
**/venv/
**/env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── ML Models & Data ────────────────────────────────────────
# Never commit trained models or real data to git
src/ml/models/trained/
models/
data/raw/
data/real/
*.pkl
*.joblib
*.h5
*.pt
*.onnx

# Synthetic data is OK to commit — real data is not
!data/synthetic/

# ─── Node / React ─────────────────────────────────────────────
node_modules/
**/node_modules/
src/dashboard/dist/
src/dashboard/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ─── Flutter / Dart ───────────────────────────────────────────
mobile/.dart_tool/
mobile/build/
mobile/.packages
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/local.properties
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
*.iml

# ─── Cloud Functions ──────────────────────────────────────────
functions/node_modules/
functions/.env
functions/.env.*

# ─── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ─── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ─── Test Artifacts ───────────────────────────────────────────
coverage.xml
test-results/

# ─── Terraform (if used for infra) ────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# ─── Build outputs ───────────────────────────────────────────
*.tgz
