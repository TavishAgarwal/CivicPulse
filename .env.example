# ============================================================
# CivicPulse — Environment Variable Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── Application ─────────────────────────────────────────────
CIVICPULSE_ENV=development           # development | staging | production
APP_NAME=CivicPulse
APP_VERSION=0.1.0
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=your-secret-key-here      # Used for JWT signing — generate with: openssl rand -hex 32

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://civicpulse:password@localhost:5432/civicpulse_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CSS_TTL_SECONDS=3600           # 1 hour
REDIS_VOLUNTEER_TTL_SECONDS=900      # 15 minutes
REDIS_HEATMAP_TTL_SECONDS=1800       # 30 minutes

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=civicpulse-main
KAFKA_TOPIC_PHARMACY=signal.pharmacy
KAFKA_TOPIC_SCHOOL=signal.school
KAFKA_TOPIC_UTILITY=signal.utility
KAFKA_TOPIC_SOCIAL=signal.social
KAFKA_TOPIC_FOODBANK=signal.foodbank
KAFKA_TOPIC_HEALTH=signal.health

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1                # Mumbai — required for India data residency
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_RAW=civicpulse-raw-data
S3_BUCKET_MODELS=civicpulse-models
S3_BUCKET_REPORTS=civicpulse-reports

# ─── ML Models ────────────────────────────────────────────────
ML_MODEL_PATH=s3://civicpulse-models/fusion/latest/
ANOMALY_MODEL_PATH=s3://civicpulse-models/anomaly/latest/
ML_RETRAIN_SCHEDULE=0 2 * * 1       # Every Monday at 2am (cron syntax)
ML_MIN_PRECISION_THRESHOLD=0.75     # Block deploy if below this
ML_TRAINING_MIN_DAYS=60             # Minimum days of data before first deploy

# ─── CSS Thresholds ───────────────────────────────────────────
# WARNING: Changing these affects dispatch logic. Update docs/signal-weights.md too.
CSS_STABLE_MAX=30
CSS_ELEVATED_MAX=55
CSS_HIGH_MAX=75
CSS_HIGH_THRESHOLD=56               # Auto-suggest dispatch at this score
CSS_CRITICAL_THRESHOLD=76           # Auto-dispatch (no human approval) at this score

# ─── Map Tiles ────────────────────────────────────────────────
# Uses OpenStreetMap tiles by default (free, no API key required)
# Override tile URL if using a custom tile server:
# MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ─── WhatsApp Business API ────────────────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ─── SMS Fallback (Twilio) ────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# ─── Push Notifications (Firebase) ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_SERVER_KEY=your-firebase-server-key

# ─── Volunteer Dispatch ───────────────────────────────────────
DISPATCH_MATCH_COUNT=5              # Number of volunteers to surface per dispatch
DISPATCH_CONFIRM_TIMEOUT_MINUTES=15 # Reassign if volunteer doesn't confirm in time
DISPATCH_FATIGUE_RECOVERY_DAYS=2    # Days before full fatigue recovery

# ─── Dispatch Matching Weights ────────────────────────────────
# These weights control volunteer match scoring (must sum to 1.0)
DISPATCH_WEIGHT_PROXIMITY=0.35
DISPATCH_WEIGHT_SKILL=0.30
DISPATCH_WEIGHT_AVAILABILITY=0.20
DISPATCH_WEIGHT_FATIGUE=0.15
FATIGUE_EXCLUSION_THRESHOLD=0.85    # Skip volunteers with fatigue above this
FATIGUE_INCREMENT_PER_DISPATCH=0.15 # Fatigue increase per dispatch assignment

# ─── Anomaly Detection ───────────────────────────────────────
ANOMALY_CONTAMINATION_RATE=0.05     # Expected proportion of outliers
ANOMALY_SEVERITY_THRESHOLD=0.7      # Severity above this triggers alert

# ─── Privacy & Compliance ─────────────────────────────────────
ANONYMIZATION_K_VALUE=5             # Minimum k-anonymity group size
DATA_RETENTION_DAYS_RAW=7           # Days to keep raw pre-anonymized data
DATA_RETENTION_DAYS_PROCESSED=730   # Days to keep processed signal data
GDPR_DPO_EMAIL=dpo@civicpulse.org

# ─── Monitoring & Observability ───────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3001

# ─── Feature Flags ────────────────────────────────────────────
FEATURE_AUTO_DISPATCH=false         # Enable auto-dispatch for CSS >= CRITICAL_THRESHOLD
FEATURE_RLHF_LAYER=false            # Enable reinforcement learning from feedback
FEATURE_PUBLIC_API=false            # Enable public API access
FEATURE_OPEN_DATA=false             # Enable open data marketplace
